# PHANTOM Karaoke Pipeline — Config Template
# Copy to .env before running. No API keys required.

# ── Server ──────────────────────────────────────────────────────────
PORT=8001

# API key — required by all /api/* routes. Set this before starting the server.
# Generate a new one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
KARAOKE_API_KEY=REPLACE_WITH_YOUR_KEY
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
TMP_DIR=./tmp

# ── Stem separation ─────────────────────────────────────────────────
# BS-Roformer model (auto-downloads on first run, ~500MB)
STEM_MODEL=model_bs_roformer_ep_317_sdr_12.9755.ckpt

# ── Lyrics ──────────────────────────────────────────────────────────
# WhisperX model size for fallback transcription (tiny/base/small/medium/large-v3)
# large-v3 = best quality; base = fastest (CPU-only use)
WHISPER_MODEL=large-v3

# ── Pitch extraction ────────────────────────────────────────────────
PITCH_HOP_MS=10          # 10ms hop (torchcrepe default)
PITCH_FMIN=50            # 50 Hz floor
PITCH_FMAX=1000          # 1000 Hz ceiling
PITCH_MEDIAN_MS=50       # vibrato filter window (ms)
PITCH_PERIODICITY=0.4    # periodicity threshold (silence gating)

# ── Video ───────────────────────────────────────────────────────────
VIDEO_FPS=30
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
PITCH_PANEL_HEIGHT=200   # height of pitch guide panel (px, bottom of frame)
LYRIC_FONT_SIZE=48
PITCH_WINDOW_MS=4000     # ms of pitch guide visible per frame

# MIDI display range for pitch bar coloring (low=blue, high=red)
MIDI_COLOR_LOW=48        # C3
MIDI_COLOR_HIGH=84       # C6
